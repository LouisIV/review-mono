# GUI CI Workflow — copy to .github/workflows/gui-build.yml once PAT has "workflow" scope

name: GUI Build

on:
  pull_request:
  push:
    branches:
      - main

jobs:
  build-macos:
    name: macOS aarch64
    runs-on: macos-latest
    steps:
      - uses: actions/checkout@v6

      - name: Setup Bun
        uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest

      - name: Setup Rust
        uses: dtolnay/rust-toolchain@stable
        with:
          targets: aarch64-apple-darwin

      - name: Install Tauri system deps
        run: brew install openssl

      - name: Install frontend deps
        working-directory: gui
        run: bun install

      - name: TypeScript check
        working-directory: gui
        run: npx tsc --noEmit

      - name: Build Tauri app
        working-directory: gui
        run: bun run build

      - name: Upload DMG artifact
        uses: actions/upload-artifact@v5
        with:
          name: review-gui-macos-aarch64
          path: gui/src-tauri/target/release/bundle/dmg/*.dmg
          if-no-files-found: warn

  cargo-check:
    name: Rust check (Linux)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6

      - name: Setup Rust
        uses: dtolnay/rust-toolchain@stable

      - name: Install Tauri system deps
        run: |
          sudo apt-get update
          sudo apt-get install -y libgtk-3-dev libwebkit2gtk-4.1-dev libappindicator3-dev librsvg2-dev libssl-dev

      - name: Cargo check
        working-directory: gui/src-tauri
        run: cargo check
